# Choose one of: sqlite (default), postgres, mongo
DB_TYPE=sqlite

# For sqlite (default)
SQLITE_FILE=./data/db.sqlite

# For Postgres
# DATABASE_URL=postgres://user:password@localhost:5432/carrental

# For MongoDB
# MONGO_URI=mongodb://localhost:27017/carrental

# JWT
JWT_SECRET=replace_this_with_a_strong_secret

# Server
PORT=3000
